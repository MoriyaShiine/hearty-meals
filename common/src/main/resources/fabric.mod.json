{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": [
	"MoriyaShiine",
	"8onfire"
  ],
  "contact": {
	"homepage": "https://modrinth.com/mod/${project_name}",
	"sources": "https://github.com/MoriyaShiine/${project_name}",
	"issues": "https://github.com/MoriyaShiine/${project_name}/issues"
  },
  "license": "All Rights Reserved",
  "icon": "assets/${mod_id}/icon.png",
  "environment": "*",
  "entrypoints": {
	"fabric-datagen": [
	  "moriyashiine.heartymeals.datagen.HeartyMealsDataGenerator"
	],
	"main": [
	  "moriyashiine.heartymeals.common.HeartyMeals"
	],
	"client": [
	  "moriyashiine.heartymeals.client.HeartyMealsClient"
	],
	"cardinal-components-entity": [
	  "moriyashiine.heartymeals.common.init.HeartyMealsEntityComponents"
	]
  },
  "mixins": [
	"${mod_id}.mixins.json"
  ],
  "accessWidener": "${mod_id}.classtweaker",
  "depends": {
	"fabricloader": "*",
	"minecraft": "~26.1",
	"java": ">=25",
	"fabric-api": "*",
	"strawberrylib": "*"
  },
  "breaks": {
	"appleskin": "*"
  },
  "custom": {
	"launchpad:compatible": true,
	"cardinal-components": [
	  "${mod_id}:food_healing"
	]
  }
}